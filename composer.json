{
    "name": "it-healer/laravel-evm",
    "description": "A library for Laravel that allows you to work with any EVM network (Ethereum, BSC, Polygon, ...): wallets, addresses, tokens, deposits and transfers.",
    "homepage": "https://github.com/it-healer/laravel-evm",
    "license": "MIT",
    "authors": [
        {
            "name": "IT-HEALER",
            "email": "info@it-healer.com"
        }
    ],
    "keywords": [
        "it-healer",
        "laravel",
        "evm",
        "ethereum",
        "bsc",
        "polygon",
        "php"
    ],
    "type": "library",
    "require": {
        "php": "^8.2",
        "ext-gmp": "*",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.92.0",
        "brick/math": "*",
        "minter/minter-php-bip-44": "^1.2",
        "kornrunner/ethereum-address": "^0.3.0",
        "kornrunner/ethereum-offline-raw-tx": "^0.8.0",
        "kornrunner/keccak": "^1.1",
        "kornrunner/rlp": "^0.3.6",
        "kornrunner/secp256k1": "^0.3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "ItHealer\\LaravelEvm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ItHealer\\LaravelEvm\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ItHealer\\LaravelEvm\\EvmServiceProvider"
            ],
            "aliases": {
                "Evm": "ItHealer\\LaravelEvm\\Facades\\Evm"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
